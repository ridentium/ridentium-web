# =============================================================================
# RIDENTIUM — Variabili d'ambiente
# Copia questo file in `.env.local` e riempi i valori reali.
# .env.local è ignorato da git — i segreti NON vanno committati.
# =============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────
# Da Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# service_role key — usata solo server-side, bypassa RLS. MAI esporre al client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Push Notifications (Web Push / VAPID) ───────────────────────────────────
# Genera con:  npx web-push generate-vapid-keys
# La PUBLIC viene esposta al client (NEXT_PUBLIC_), la PRIVATE resta server-side.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ridentium.it

# ── Secret per API webhook/cron interne ────────────────────────────────────
# Protegge /api/notify/*  e pushsubscriptionchange.
# Genera con:  openssl rand -base64 32
NOTIFY_SECRET=

# ── API key per form landing esterno (Gift Box) ────────────────────────────
# Se impostata, /api/crm/contatti richiede header `x-api-key`.
# Genera con:  openssl rand -base64 24
CRM_API_KEY=

# ── Email (Gmail SMTP via nodemailer) ───────────────────────────────────────
# GMAIL_APP_PASSWORD = app password generata da account Google (non la password normale)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── AI chat (Lina) ──────────────────────────────────────────────────────────
GROQ_API_KEY=
